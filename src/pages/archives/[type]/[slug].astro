---
import { getCollection, render } from "astro:content";
import ArchiveDeck from "../../../components/ArchiveDeck.astro";
import ConsolePanel from "../../../components/ConsolePanel.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { archiveSlug, archiveType, resolveArchive, sortArchives } from "../../../lib/archives";

export async function getStaticPaths() {
  const entries = sortArchives(await getCollection("archives"));

  return entries.map((entry) => {
    const resolved = resolveArchive(entry);
    return {
      params: {
        type: resolved.type,
        slug: resolved.slug
      },
      props: { entry, resolved }
    };
  });
}

const { entry, resolved } = Astro.props;
const { Content } = await render(entry);
const archiveHref = `/archive?${new URLSearchParams({
  type: resolved.type,
  slug: resolved.slug
}).toString()}`;

if (
  archiveType(entry) !== Astro.params.type ||
  archiveSlug(entry) !== Astro.params.slug
) {
  throw new Error("Archive route mismatch.");
}
---

<BaseLayout
  title={`${entry.data.title} | Matrix Archive`}
  description={entry.data.excerpt}
  pageClass="page-archive-file"
>
  <main class="archive-file-shell site-shell">
    <div class="archive-file-topbar">
      <a class="action-link action-link--back" href={archiveHref}>
        <span>&lt;- ARCHIVE</span>
      </a>
      <span class="archive-file-topbar__id">{resolved.fileId}</span>
    </div>

    <section class="archive-file-hero">
      <div class="archive-file-hero__copy">
        <p class="eyebrow">[ ARCHIVE FILE ]</p>
        <h1>{entry.data.title}</h1>
        <p class="archive-file-hero__thesis">{entry.data.thesis ?? entry.data.excerpt}</p>
      </div>

      <div class="archive-file-hero__facts">
        <span>
          ASSET
          <strong>{entry.data.asset}</strong>
        </span>
        <span>
          TYPE
          <strong>{entry.data.type.toUpperCase()}</strong>
        </span>
        <span>
          UPDATED
          <strong>{resolved.dateDisplay}</strong>
        </span>
      </div>
    </section>

    <section class="archive-file-showcase">
      <div class="archive-file-showcase__media">
        <ArchiveDeck
          title={entry.data.title}
          asset={entry.data.asset}
          type={entry.data.type}
          excerpt={entry.data.excerpt}
          cover={entry.data.cover}
          slides={entry.data.slideImages}
        />
      </div>

      <aside class="archive-file-showcase__meta">
        <ConsolePanel title="THESIS">
          <p class="console-copy">{entry.data.thesis ?? entry.data.excerpt}</p>
        </ConsolePanel>

        <ConsolePanel title="DOWNLOADS">
          <div class="download-stack">
            {
              entry.data.pptx && (
                <a class="action-link" href={entry.data.pptx} download>
                  <span>DOWNLOAD PPTX</span>
                  <span aria-hidden="true">-&gt;</span>
                </a>
              )
            }
            {
              entry.data.markdownDownload && (
                <a class="action-link" href={entry.data.markdownDownload} download>
                  <span>DOWNLOAD MARKDOWN</span>
                  <span aria-hidden="true">-&gt;</span>
                </a>
              )
            }
          </div>
        </ConsolePanel>

        <ConsolePanel title="TIMEFRAMES">
          <div class="detail-meta">
            <div class="detail-meta__row">
              <span>SYMBOL</span>
              <strong>{entry.data.tradingviewSymbol}</strong>
            </div>
            {
              entry.data.tradingviewTimeframes.map((timeframe, index) => (
                <div class="detail-meta__row">
                  <span>{index === 0 ? "TF-01" : index === 1 ? "TF-02" : "TF-03"}</span>
                  <strong>{timeframe}</strong>
                </div>
              ))
            }
          </div>
          <a class="action-link" href={archiveHref}>
            <span>OPEN ARCHIVE CONSOLE</span>
            <span aria-hidden="true">-&gt;</span>
          </a>
        </ConsolePanel>
      </aside>
    </section>

    <ConsolePanel title="WRITTEN ARCHIVE" className="archive-article">
      <article class="prose">
        <Content />
      </article>
    </ConsolePanel>
  </main>
</BaseLayout>
