---
//[Carrega dados, layout e helpers usados por cada pagina estatica de dossier.]
import { getCollection, render } from "astro:content";
import ArchiveDeck from "../../../components/ArchiveDeck.astro";
import ConsolePanel from "../../../components/ConsolePanel.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  archiveSlug,
  archiveType,
  displayTradingviewTimeframes,
  resolveArchive,
  resolveArchiveMedia,
  sortArchives,
  typeLabel
} from "../../../lib/archives";

//[Gera rotas estaticas para cada dossier usando tipo normalizado e slug canonical.]
export async function getStaticPaths() {
  const entries = sortArchives(await getCollection("archives"));

  return entries.map((entry) => {
    const resolved = resolveArchive(entry);
    return {
      params: {
        type: resolved.type,
        slug: resolved.slug
      },
      props: { entry, resolved }
    };
  });
}

//[Resolve conteudo da pagina atual, midias publicadas e link de retorno ao console.]
const { entry, resolved } = Astro.props;
const { Content } = await render(entry);
const media = resolveArchiveMedia(entry);
const displayTimeframes = displayTradingviewTimeframes(
  entry.data.tradingviewTimeframes
);
const archiveHref = `/archive?${new URLSearchParams({
  type: resolved.type,
  slug: resolved.slug
}).toString()}`;

//[Falha cedo quando parametros de rota nao batem com entry recebido pelo build.]
if (
  archiveType(entry) !== Astro.params.type ||
  archiveSlug(entry) !== Astro.params.slug
) {
  throw new Error("Archive route mismatch.");
}
---

<BaseLayout
  title={`${entry.data.title} | Matrix Archive`}
  description={resolved.preview}
  pageClass="page-archive-file"
>
  <main class="archive-file-shell site-shell">
    <div class="archive-file-topbar">
      <a class="action-link action-link--back" href={archiveHref}>
        <span>&lt;- ARCHIVE</span>
      </a>
      <span class="archive-file-topbar__id">{resolved.fileId}</span>
    </div>

    <section class="archive-file-hero">
      <div class="archive-file-hero__copy">
        <p class="eyebrow">[ ARCHIVE FILE ]</p>
        <h1>{entry.data.title}</h1>
        <p class="archive-file-hero__thesis">{resolved.preview}</p>
      </div>

      <div class="archive-file-hero__facts">
        <span>
          ASSET
          <strong>{entry.data.asset}</strong>
        </span>
        <span>
          TYPE
          <strong>{typeLabel(entry.data.type)}</strong>
        </span>
        <span>
          BIAS
          <strong>{entry.data.bias}</strong>
        </span>
        <span>
          SLOT UTC
          <strong>{resolved.slotDisplay}</strong>
        </span>
        <span>
          CAPTURE UTC
          <strong>{resolved.captureDisplay}</strong>
        </span>
        <span>
          DATE
          <strong>{resolved.dateDisplay}</strong>
        </span>
      </div>
    </section>

    <section class="archive-file-showcase">
      <div class="archive-file-showcase__media">
        <ArchiveDeck
          title={entry.data.title}
          asset={entry.data.asset}
          type={entry.data.type}
          preview={resolved.preview}
          slides={media}
        />
      </div>

      <aside class="archive-file-showcase__meta">
        <ConsolePanel title="BIAS">
          <div class="signal-stack">
            <span
              class:list={[
                "bias-tag",
                "bias-tag--large",
                `bias-tag--${entry.data.bias.toLowerCase()}`
              ]}
            >
              {entry.data.bias}
            </span>
            <p class="console-copy">{resolved.preview}</p>
          </div>
        </ConsolePanel>

        <ConsolePanel title="TIMEFRAMES">
          <div class="detail-meta">
            <div class="detail-meta__row">
              <span>SYMBOL</span>
              <strong>{entry.data.tradingviewSymbol}</strong>
            </div>
            {
              displayTimeframes.map((timeframe, index) => (
                <div class="detail-meta__row">
                  <span>{`TF-${String(index + 1).padStart(2, "0")}`}</span>
                  <strong>{timeframe}</strong>
                </div>
              ))
            }
          </div>
          <a class="action-link" href={archiveHref}>
            <span>OPEN ARCHIVE CONSOLE</span>
            <span class="action-link__chevron" aria-hidden="true"></span>
          </a>
        </ConsolePanel>
      </aside>
    </section>

    <ConsolePanel title="WRITTEN ARCHIVE" className="archive-article">
      <article class="prose">
        <Content />
      </article>
    </ConsolePanel>
  </main>
</BaseLayout>
