---
//[Carrega layout base e gerador de wordmark para montar entrada visual inicial.]
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildGlitchWordmark } from "../lib/glitchWordmark";

//[Prepara letras animadas do titulo principal antes de renderizar markup da landing.]
const titleWords = buildGlitchWordmark(["MATRIX", "ARCHIVE"]);
---

<BaseLayout
  title="Matrix Archive"
  description="Matrix Archive access point."
  pageClass="page-landing"
>
  <main class="landing">
    <div class="landing__topbar">
      <span class="landing__coord landing__coord--top-left">
        COORDINATES
        <strong>// -24.715272 ; -53742531</strong>
      </span>
      <span class="landing__coord landing__coord--top-right">
        SIGNAL
        <strong>// STABLE</strong>
      </span>
    </div>

    <div class="landing__middle">
      <h1 class="landing__title" transition:name="matrix-title" aria-label="MATRIX ARCHIVE">
        {titleWords.map(({ glyphs }) => (
          <span class="landing__word" aria-hidden="true">
            {glyphs.map(({ glyph, profile, index }) => (
              <span
                class="landing__glyph"
                data-glyph={glyph}
                style={`--glyph-index:${index};--upper-delay:${profile.upperDelay}s;--upper-duration:${profile.upperDuration}s;--lower-delay:${profile.lowerDelay}s;--lower-duration:${profile.lowerDuration}s;--noise-a-delay:${profile.noiseADelay}s;--noise-a-duration:${profile.noiseADuration}s;--noise-b-delay:${profile.noiseBDelay}s;--noise-b-duration:${profile.noiseBDuration}s;`}
              >
                <span class="landing__glyph-core" data-glyph={glyph}>{glyph}</span>
              </span>
            ))}
          </span>
        ))}
      </h1>
    </div>

    <div class="landing__bottom">
      <a class="landing__entry action-link action-link--large" href="/archive">
        <span>[ JACK IN ]</span>
      </a>
      <span class="landing__coord landing__coord--bottom-left">
        SINCE
        <strong>// 20.05.26</strong>
      </span>
    </div>
  </main>
</BaseLayout>
