---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 | Matrix Dossier" pageClass="page-404">
  <main class="not-found site-shell">
    <p class="eyebrow">[ FILE MISSING ]</p>
    <h1>404</h1>
    <p>Requested dossier not present in archive index.</p>
    <a class="action-link" href="/archive">
      <span>RETURN TO ARCHIVE</span>
      <span aria-hidden="true">-&gt;</span>
    </a>
  </main>
</BaseLayout>
