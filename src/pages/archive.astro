---
import { getCollection } from "astro:content";
import ArchiveConsole from "../components/ArchiveConsole.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { resolveDossier, sortDossiers, sortTypes } from "../lib/dossiers";

const entries = sortDossiers(await getCollection("dossiers"));
const resolved = entries.map(resolveDossier);
const types = sortTypes(resolved.map((item) => item.type));
const initialType = types[0] ?? "topdown";

const dossiers = resolved.map((item) => ({
  id: item.entry.id,
  type: item.type,
  typeLabel: item.typeLabel,
  url: item.url,
  asset: item.entry.data.asset,
  title: item.entry.data.title,
  excerpt: item.entry.data.excerpt,
  thesis: item.entry.data.thesis,
  dateDisplay: item.dateDisplay,
  fileId: item.fileId,
  tradingviewSymbol: item.entry.data.tradingviewSymbol,
  tradingviewTimeframes: item.entry.data.tradingviewTimeframes
}));
---

<BaseLayout
  title="Matrix Dossier Archive"
  description="Archive console for Matrix Dossier."
  pageClass="page-archive"
>
  <main class="archive-shell site-shell">
    <header class="archive-header">
      <div>
        <p class="eyebrow">[ ARCHIVE CONSOLE ]</p>
        <h1 transition:name="matrix-title">DOSSIER ARCHIVE</h1>
      </div>
      <div class="archive-header__meta">
        <span>ACCESS LEVEL</span>
        <strong>//ALL</strong>
      </div>
    </header>

    <ArchiveConsole dossiers={dossiers} types={types} initialType={initialType} />
  </main>
</BaseLayout>
