---
//[Carrega conteudo publicado, componentes visuais e helpers de resolucao para console.]
import { getCollection, render } from "astro:content";
import ArchiveConsole from "../components/ArchiveConsole.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildGlitchWordmark } from "../lib/glitchWordmark";
import {
  displayTradingviewTimeframes,
  resolveArchive,
  sortArchives,
  sortTypes
} from "../lib/archives";

//[Resolve todos os dossiers em ordem recente e prepara corpo renderizavel para feed.]
const entries = sortArchives(await getCollection("archives"));
const archives = await Promise.all(
  entries.map(async (entry) => {
    const resolved = resolveArchive(entry);
    const { Content } = await render(entry);
    const tradingviewTimeframes = displayTradingviewTimeframes(
      entry.data.tradingviewTimeframes
    );

    return {
      id: entry.id,
      slug: resolved.slug,
      type: resolved.type,
      typeLabel: resolved.typeLabel,
      url: resolved.url,
      asset: entry.data.asset,
      bias: entry.data.bias,
      title: entry.data.title,
      dateDisplay: resolved.dateDisplay,
      fileId: resolved.fileId,
      slotTimeUtc: entry.data.slotTimeUtc.toISOString(),
      tradingviewSymbol: entry.data.tradingviewSymbol,
      tradingviewTimeframes,
      timeframeLabel: tradingviewTimeframes.join(" / "),
      Content
    };
  })
);
//[Calcula filtros iniciais e wordmark exibido no topo da experiencia de arquivo.]
const types = sortTypes(archives.map((item) => item.type));
const initialType = types[0] ?? "continuous";
const titleWords = buildGlitchWordmark(["ARCHIVE"]);
---

<BaseLayout
  title="Matrix Archive"
  description="Archive console for Matrix Archive."
  pageClass="page-archive"
>
  <main class="archive-shell site-shell">
    <header class="archive-header">
      <div class="archive-header__wordmark">
        <h1
          class="landing__title archive-header__title"
          transition:name="matrix-title"
          aria-label="ARCHIVE"
        >
          {titleWords.map(({ glyphs }) => (
            <span class="landing__word" aria-hidden="true">
              {glyphs.map(({ glyph, profile, index }) => (
                <span
                  class="landing__glyph"
                  data-glyph={glyph}
                  style={`--glyph-index:${index};--upper-delay:${profile.upperDelay}s;--upper-duration:${profile.upperDuration}s;--lower-delay:${profile.lowerDelay}s;--lower-duration:${profile.lowerDuration}s;--noise-a-delay:${profile.noiseADelay}s;--noise-a-duration:${profile.noiseADuration}s;--noise-b-delay:${profile.noiseBDelay}s;--noise-b-duration:${profile.noiseBDuration}s;`}
                >
                  <span class="landing__glyph-core" data-glyph={glyph}>{glyph}</span>
                </span>
              ))}
            </span>
          ))}
        </h1>
        <p class="eyebrow archive-header__eyebrow">[ CONSOLE ]</p>
      </div>
      <div class="archive-header__meta">
        <span>ACCESS LEVEL</span>
        <strong>//ALL</strong>
      </div>
    </header>

    <ArchiveConsole archives={archives} types={types} initialType={initialType} />
  </main>
</BaseLayout>
