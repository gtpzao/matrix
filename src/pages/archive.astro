---
import { getCollection, render } from "astro:content";
import ArchiveConsole from "../components/ArchiveConsole.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { resolveArchive, sortArchives, sortTypes } from "../lib/archives";

const entries = sortArchives(await getCollection("archives"));
const archives = await Promise.all(
  entries.map(async (entry) => {
    const resolved = resolveArchive(entry);
    const { Content } = await render(entry);

    return {
      id: entry.id,
      slug: resolved.slug,
      type: resolved.type,
      typeLabel: resolved.typeLabel,
      url: resolved.url,
      asset: entry.data.asset,
      title: entry.data.title,
      excerpt: entry.data.excerpt,
      thesis: entry.data.thesis,
      dateDisplay: resolved.dateDisplay,
      fileId: resolved.fileId,
      tradingviewSymbol: entry.data.tradingviewSymbol,
      tradingviewTimeframes: entry.data.tradingviewTimeframes,
      Content
    };
  })
);
const types = sortTypes(archives.map((item) => item.type));
const initialType = types[0] ?? "continuous";
---

<BaseLayout
  title="Matrix Archive"
  description="Archive console for Matrix Archive."
  pageClass="page-archive"
>
  <main class="archive-shell site-shell">
    <header class="archive-header">
      <div>
        <p class="eyebrow">[ ARCHIVE CONSOLE ]</p>
        <h1 transition:name="matrix-title">ARCHIVE</h1>
      </div>
      <div class="archive-header__meta">
        <span>ACCESS LEVEL</span>
        <strong>//ALL</strong>
      </div>
    </header>

    <ArchiveConsole archives={archives} types={types} initialType={initialType} />
  </main>
</BaseLayout>
