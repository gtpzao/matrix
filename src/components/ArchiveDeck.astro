---
interface Props {
  title: string;
  asset: string;
  type: string;
  preview: string;
  slides?: string[];
}

const {
  title,
  asset,
  type,
  preview,
  slides = []
} = Astro.props;

const media = [...new Set(slides.filter(Boolean))];
---

<section class="archive-deck">
  {
    media.length > 0 ? (
      media.map((image, index) => (
        <figure class="deck-media">
          <img
            src={image}
            alt={`${title} frame ${index + 1}`}
            loading={index === 0 ? "eager" : "lazy"}
          />
        </figure>
      ))
    ) : (
      <article class="deck-placeholder">
        <span class="deck-placeholder__eyebrow">ARCHIVE VISUAL SLOT OPEN</span>
        <h2>{asset} // {type.toUpperCase()}</h2>
        <p>{preview}</p>
        <span class="deck-placeholder__note">
          no capture linked for this dossier yet
        </span>
      </article>
    )
  }
</section>
