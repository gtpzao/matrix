---
import ConsolePanel from "./ConsolePanel.astro";

type ArchiveRenderable = {
  id: string;
  slug: string;
  type: string;
  typeLabel: string;
  url: string;
  asset: string;
  title: string;
  excerpt: string;
  thesis?: string;
  dateDisplay: string;
  fileId: string;
  tradingviewSymbol: string;
  tradingviewTimeframes: string[];
  Content: any;
};

interface Props {
  archives: ArchiveRenderable[];
  types: string[];
  initialType: string;
}

const { archives, types, initialType } = Astro.props;

const typeCopy: Record<string, string> = {
  continuous: "everlasting",
  instant: "immediate"
};

const timeframeDefaults: Record<string, string[]> = {
  continuous: ["M", "W", "D"],
  instant: ["240", "120", "60"]
};

const archiveIndex = archives.map(({ Content, ...archive }) => archive);
const initialIntervals = timeframeDefaults[initialType] ?? ["--", "--", "--"];
---

<section class="archive-console" data-archive-console>
  <div class="archive-console__grid">
    <ConsolePanel title="TYPES" className="archive-console__types">
      <div class="type-list">
        {
          types.map((type) => (
            <button
              class:list={["type-button", { "is-active": type === initialType }]}
              type="button"
              data-type-button={type}
            >
              <span class="type-button__title">{type.toUpperCase()}</span>
              <span class="type-button__copy">{typeCopy[type] ?? "branch active"}</span>
            </button>
          ))
        }
      </div>
    </ConsolePanel>

    <ConsolePanel title="RECENT" className="archive-console__feed">
      <div class="feed-list">
        {
          archives.map(({ Content, ...archive }, order) => (
            <article
              class:list={[
                "archive-item",
                { "is-hidden": archive.type !== initialType }
              ]}
              data-archive-item={archive.id}
              data-archive-type={archive.type}
              data-archive-order={order}
              hidden={archive.type !== initialType}
            >
              <button
                type="button"
                class="archive-item__toggle"
                aria-expanded="false"
                data-archive-toggle={archive.id}
              >
                <span class="archive-item__topline">
                  <span class="archive-item__asset">{archive.asset}</span>
                  <span class="archive-item__date">{archive.dateDisplay}</span>
                </span>
                <span class="archive-item__title">{archive.title}</span>
                <span class="archive-item__excerpt">{archive.excerpt}</span>
                <span class="archive-item__indicator" aria-hidden="true">+</span>
              </button>

              <div class="archive-item__body" data-archive-body={archive.id} hidden>
                <article class="archive-item__content prose prose--archive">
                  <Content />
                </article>
              </div>
            </article>
          ))
        }
      </div>
    </ConsolePanel>

    <ConsolePanel title="ASSET" className="archive-console__detail">
      <div class="detail-stack">
        {
          [0, 1, 2].map((index) => (
            <div class="widget-shell widget-shell--archive">
              <div class="widget-shell__header">
                <span data-detail-symbol={index}>--</span>
                <span data-detail-interval={index}>{initialIntervals[index] ?? "--"}</span>
              </div>
              <div class="tv-chart tv-chart--compact" data-detail-chart={index}>
                <div class="tv-chart__fallback">SELECT ARCHIVE</div>
              </div>
            </div>
          ))
        }

        <div class="detail-meta detail-meta--archive">
          <div class="detail-meta__row">
            <span>ASSET</span>
            <strong data-detail-asset>--</strong>
          </div>
          <div class="detail-meta__row">
            <span>TYPE</span>
            <strong data-detail-type>{initialType.toUpperCase()}</strong>
          </div>
          <div class="detail-meta__row">
            <span>UPDATED</span>
            <strong data-detail-date>--</strong>
          </div>
          <div class="detail-meta__row detail-meta__row--stack">
            <span>FILE ID</span>
            <strong data-detail-fileid>--</strong>
          </div>
        </div>

        <a
          class="action-link action-link--disabled"
          href="#"
          aria-disabled="true"
          data-detail-link
        >
          <span>OPEN ARCHIVE</span>
          <span aria-hidden="true">-&gt;</span>
        </a>
      </div>
    </ConsolePanel>
  </div>
</section>

<script is:inline define:vars={{ archiveIndex, initialType, types, timeframeDefaults }}>
  const initArchiveConsole = () => {
    const root = document.querySelector("[data-archive-console]");
    if (!root || root.dataset.archiveBound === "true") return;
    root.dataset.archiveBound = "true";

    const typeButtons = [...root.querySelectorAll("[data-type-button]")];
    const archiveItems = [...root.querySelectorAll("[data-archive-item]")];
    const toggleButtons = [...root.querySelectorAll("[data-archive-toggle]")];
    const bodyNodes = [...root.querySelectorAll("[data-archive-body]")];
    const chartNodes = [...root.querySelectorAll("[data-detail-chart]")];
    const symbolNodes = [...root.querySelectorAll("[data-detail-symbol]")];
    const intervalNodes = [...root.querySelectorAll("[data-detail-interval]")];
    const assetNode = root.querySelector("[data-detail-asset]");
    const typeNode = root.querySelector("[data-detail-type]");
    const dateNode = root.querySelector("[data-detail-date]");
    const fileIdNode = root.querySelector("[data-detail-fileid]");
    const linkNode = root.querySelector("[data-detail-link]");

    const archiveMap = new Map(archiveIndex.map((archive) => [archive.id, archive]));
    const itemMap = new Map(
      archiveItems.map((item) => [item.dataset.archiveItem, item])
    );
    const bodyMap = new Map(
      bodyNodes.map((body) => [body.dataset.archiveBody, body])
    );
    const toggleMap = new Map(
      toggleButtons.map((button) => [button.dataset.archiveToggle, button])
    );

    const defaultIntervalsForType = (type) =>
      timeframeDefaults[type] ?? ["--", "--", "--"];

    const getVisibleLimit = () =>
      window.matchMedia("(max-width: 840px)").matches ? 15 : 30;

    const renderWidgetFallback = (label) => {
      chartNodes.forEach((node) => {
        node.innerHTML = `<div class="tv-chart__fallback">${label}</div>`;
      });
    };

    const setDetailIntervals = (intervals) => {
      intervalNodes.forEach((node, index) => {
        node.textContent = intervals[index] ?? "--";
      });
    };

    const setDetailSymbol = (symbol) => {
      symbolNodes.forEach((node) => {
        node.textContent = symbol ?? "--";
      });
    };

    const syncTypeButtons = () => {
      typeButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.typeButton === activeType);
      });
    };

    const collapseArchive = (archiveId) => {
      const item = itemMap.get(archiveId);
      const body = bodyMap.get(archiveId);
      const toggle = toggleMap.get(archiveId);

      if (item) item.classList.remove("is-active");
      if (body) body.hidden = true;
      if (toggle) toggle.setAttribute("aria-expanded", "false");
    };

    const collapseAll = () => {
      archiveIndex.forEach((archive) => collapseArchive(archive.id));
    };

    const syncArchiveLocation = () => {
      const params = new URLSearchParams(window.location.search);
      const activeArchive = activeArchiveId ? archiveMap.get(activeArchiveId) : null;
      const isDefaultState = activeType === initialType && !activeArchive;
      let nextUrl = window.location.pathname;

      if (!isDefaultState) {
        params.set("type", activeType);

        if (activeArchive?.slug) {
          params.set("slug", activeArchive.slug);
        } else {
          params.delete("slug");
        }

        const query = params.toString();
        nextUrl = query
          ? `${window.location.pathname}?${query}`
          : window.location.pathname;
      }

      window.history.replaceState(window.history.state, "", nextUrl);
    };

    const resolveInitialSelection = () => {
      const params = new URLSearchParams(window.location.search);
      const requestedType = params.get("type");
      const requestedSlug = params.get("slug");
      const archiveFromSlug = requestedSlug
        ? archiveIndex.find((archive) => archive.slug === requestedSlug)
        : null;
      const typeFromQuery = types.includes(requestedType ?? "")
        ? requestedType
        : archiveFromSlug?.type ?? initialType;
      const archiveFromQuery = requestedSlug
        ? archiveIndex.find(
            (archive) =>
              archive.slug === requestedSlug && archive.type === typeFromQuery
          )
        : null;

      return {
        type: typeFromQuery,
        archiveId: archiveFromQuery?.id ?? null
      };
    };

    let widgetRenderNonce = 0;
    let activeType = initialType;
    let activeArchiveId = null;

    const ensureTradingView = async () => {
      if (window.TradingView?.widget) return true;

      let script = document.querySelector("script[data-tv-script]");
      if (!script) {
        script = document.createElement("script");
        script.src = "https://s3.tradingview.com/tv.js";
        script.async = true;
        script.dataset.tvScript = "true";
        document.head.appendChild(script);
      }

      await new Promise((resolve, reject) => {
        if (window.TradingView?.widget) {
          resolve(true);
          return;
        }

        script.addEventListener("load", () => resolve(true), { once: true });
        script.addEventListener("error", () => reject(new Error("tv-load")), {
          once: true
        });
      }).catch(() => false);

      return Boolean(window.TradingView?.widget);
    };

    const renderWidgets = async (archive) => {
      const nonce = ++widgetRenderNonce;

      if (!archive) {
        renderWidgetFallback("SELECT ARCHIVE");
        return;
      }

      chartNodes.forEach((node) => {
        node.innerHTML = "";
      });

      const tvReady = await ensureTradingView();
      if (!tvReady || nonce !== widgetRenderNonce) {
        renderWidgetFallback("TRADINGVIEW UNAVAILABLE");
        return;
      }

      const commonConfig = {
        symbol: archive.tradingviewSymbol,
        theme: "dark",
        style: "1",
        locale: "en",
        autosize: true,
        allow_symbol_change: false,
        hide_top_toolbar: true,
        hide_legend: true,
        save_image: false,
        backgroundColor: "#020603",
        gridColor: "rgba(157,255,191,0.08)"
      };

      chartNodes.forEach((node, index) => {
        const frameId = `tv-archive-${index}`;
        node.innerHTML = `<div id="${frameId}"></div>`;

        new window.TradingView.widget({
          ...commonConfig,
          interval: archive.tradingviewTimeframes[index],
          container_id: frameId
        });
      });
    };

    const clearDetail = async () => {
      activeArchiveId = null;
      if (assetNode) assetNode.textContent = "--";
      if (typeNode) typeNode.textContent = activeType.toUpperCase();
      if (dateNode) dateNode.textContent = "--";
      if (fileIdNode) fileIdNode.textContent = "--";
      if (linkNode) {
        linkNode.href = "#";
        linkNode.setAttribute("aria-disabled", "true");
        linkNode.classList.add("action-link--disabled");
      }

      setDetailSymbol("--");
      setDetailIntervals(defaultIntervalsForType(activeType));
      syncArchiveLocation();
      await renderWidgets(null);
    };

    const updateFeedVisibility = () => {
      let shown = 0;
      const visibleLimit = getVisibleLimit();

      archiveItems.forEach((item) => {
        const matchesType = item.dataset.archiveType === activeType;
        const visible = matchesType && shown < visibleLimit;

        item.hidden = !visible;
        item.classList.toggle("is-hidden", !visible);

        if (matchesType) {
          shown += 1;
        }
      });

      const activeItem = activeArchiveId ? itemMap.get(activeArchiveId) : null;
      if (activeItem?.hidden) {
        collapseAll();
        void clearDetail();
      }
    };

    const openArchive = async (archiveId) => {
      const archive = archiveMap.get(archiveId);
      const item = itemMap.get(archiveId);
      const body = bodyMap.get(archiveId);
      const toggle = toggleMap.get(archiveId);

      if (!archive || !item || !body || !toggle) return;

      collapseAll();
      activeArchiveId = archive.id;
      item.classList.add("is-active");
      body.hidden = false;
      toggle.setAttribute("aria-expanded", "true");

      if (assetNode) assetNode.textContent = archive.asset;
      if (typeNode) typeNode.textContent = archive.typeLabel;
      if (dateNode) dateNode.textContent = archive.dateDisplay;
      if (fileIdNode) fileIdNode.textContent = archive.fileId;
      if (linkNode) {
        linkNode.href = archive.url;
        linkNode.removeAttribute("aria-disabled");
        linkNode.classList.remove("action-link--disabled");
      }

      setDetailSymbol(archive.tradingviewSymbol);
      setDetailIntervals(archive.tradingviewTimeframes);
      syncArchiveLocation();
      await renderWidgets(archive);
    };

    const setActiveType = async (type) => {
      activeType = type;
      collapseAll();
      syncTypeButtons();
      updateFeedVisibility();
      await clearDetail();
    };

    typeButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const nextType = button.dataset.typeButton;
        if (!nextType || nextType === activeType) return;
        await setActiveType(nextType);
      });
    });

    toggleButtons.forEach((button) => {
      button.addEventListener("click", async () => {
        const archiveId = button.dataset.archiveToggle;
        if (!archiveId) return;

        if (activeArchiveId === archiveId) {
          collapseArchive(archiveId);
          await clearDetail();
          return;
        }

        await openArchive(archiveId);
      });
    });

    const initialSelection = resolveInitialSelection();
    activeType = initialSelection.type;

    syncTypeButtons();
    updateFeedVisibility();
    void clearDetail().then(async () => {
      if (initialSelection.archiveId) {
        await openArchive(initialSelection.archiveId);
      }
    });

    window.addEventListener("resize", () => {
      updateFeedVisibility();
    });
  };

  if (!window.__matrixArchiveConsoleInit) {
    window.__matrixArchiveConsoleInit = true;
    document.addEventListener("astro:page-load", initArchiveConsole);
    initArchiveConsole();
  } else {
    initArchiveConsole();
  }
</script>
