---
import ConsolePanel from "./ConsolePanel.astro";
import { compareAssets, typeLabel } from "../lib/archives";

//[Descreve payload serializado para o console interativo sem carregar corpo duas vezes.]
type ArchiveRenderable = {
  id: string;
  slug: string;
  type: string;
  typeLabel: string;
  url: string;
  asset: string;
  bias: string;
  title: string;
  dateDisplay: string;
  fileId: string;
  slotTimeUtc: string;
  tradingviewSymbol: string;
  tradingviewTimeframes: string[];
  timeframeLabel: string;
  Content: any;
};

//[Guarda resumo por ativo usado para montar filtros expansivos por tipo.]
type AssetFilterMeta = {
  asset: string;
  count: number;
  latestArchiveId: string;
};

type TimeframeFilterMeta = {
  timeframe: string;
  count: number;
};

//[Agrupa contagem total e ativos disponiveis dentro de cada tipo de dossier.]
type TypeFilterMeta = {
  type: string;
  totalCount: number;
  assets: AssetFilterMeta[];
  timeframes: TimeframeFilterMeta[];
};

//[Declara props recebidas da rota archive apos conteudo ser resolvido server-side.]
interface Props {
  archives: ArchiveRenderable[];
  types: string[];
  initialType: string;
}

const { archives, types, initialType } = Astro.props;

//[Mapeia copy curta de cada tipo para subtitulo visual dos cards de filtro.]
const typeCopy: Record<string, string> = {
  continuous: "everlasting",
  "parallax-relative": "relative",
  instant: "immediate"
};

//[Define timeframes fallback para painel asset quando nenhum arquivo esta selecionado.]
const timeframeDefaults: Record<string, string[]> = {
  continuous: ["1W", "1D", "4h"],
  "parallax-relative": ["1D"],
  instant: ["1h", "2h"]
};
//[Traduz labels exibidos para intervalos aceitos pelo widget externo TradingView.]
const timeframeWidgetMap: Record<string, string> = {
  "1W": "W",
  "1D": "D",
  "4h": "240",
  "2h": "120",
  "1h": "60",
  "30": "30",
  "15": "15",
  M: "M",
  W: "W",
  D: "D",
  "240": "240",
  "120": "120",
  "60": "60"
};

//[Remove componente renderizavel do indice enviado ao browser para reduzir payload serializado.]
const archiveIndex = archives.map(({ Content, ...archive }) => archive);
//[Calcula quantidade maxima de widgets necessaria conforme maior dossier publicado.]
const widgetCount = Math.max(
  1,
  ...archives.map((archive) => archive.tradingviewTimeframes.length)
);
//[Identifica batch mais recente por tipo para marcar itens antigos no feed.]
const latestBatchKeyByType = new Map(
  types.map((type) => [
    type,
    archiveIndex.find((archive) => archive.type === type)?.slotTimeUtc ?? null
  ])
);
//[Precalcula filtros por tipo e ativo para evitar recomputar dentro do script client-side.]
const typeFilterIndex: TypeFilterMeta[] = types.map((type) => {
  const items = archiveIndex.filter((archive) => archive.type === type);
  const assetMap = new Map<string, AssetFilterMeta>();
  const timeframeMap = new Map<string, TimeframeFilterMeta>();

  items.forEach((archive) => {
    archive.tradingviewTimeframes.forEach((timeframe) => {
      const currentTimeframe = timeframeMap.get(timeframe);
      if (currentTimeframe) {
        currentTimeframe.count += 1;
        return;
      }

      timeframeMap.set(timeframe, {
        timeframe,
        count: 1
      });
    });

    const current = assetMap.get(archive.asset);
    if (current) {
      current.count += 1;
      return;
    }

    assetMap.set(archive.asset, {
      asset: archive.asset,
      count: 1,
      latestArchiveId: archive.id
    });
  });

  const timeframeOrder = timeframeDefaults[type] ?? [];
  const timeframes = [...timeframeMap.values()].sort((left, right) => {
    const leftOrder = timeframeOrder.indexOf(left.timeframe);
    const rightOrder = timeframeOrder.indexOf(right.timeframe);

    if (leftOrder === -1 && rightOrder === -1) {
      return left.timeframe.localeCompare(right.timeframe);
    }
    if (leftOrder === -1) return 1;
    if (rightOrder === -1) return -1;
    return leftOrder - rightOrder;
  });

  return {
    type,
    totalCount: items.length,
    assets: [...assetMap.values()].sort((left, right) =>
      compareAssets(left.asset, right.asset)
    ),
    timeframes
  };
});
//[Prepara intervalos iniciais para headers dos widgets antes de qualquer selecao.]
const initialIntervals = (
  timeframeDefaults[initialType] ?? ["--"]
).slice(0, widgetCount);
const typeDisplayLabels = Object.fromEntries(
  types.map((type) => [type, typeLabel(type)])
);
//[Formata contagens com dois digitos para manter largura visual previsivel.]
const formatCount = (value: number) => String(value).padStart(2, "0");
---

<section class="archive-console" data-archive-console>
  <div class="archive-console__grid">
    <ConsolePanel title="TYPES" className="archive-console__types">
      <div class="type-list">
        {
          types.map((type) => {
            const typeFilter = typeFilterIndex.find((entry) => entry.type === type);

            return (
              <article
                class:list={["type-card", { "is-active": type === initialType }]}
                data-type-card={type}
              >
                <div class="type-card__bar">
                  <button
                    class:list={["type-button", { "is-active": type === initialType }]}
                    type="button"
                    data-type-button={type}
                  >
                    <span class="type-button__title">
                      {typeDisplayLabels[type] ?? type.toUpperCase()}
                    </span>
                    <span class="type-button__copy">{typeCopy[type] ?? "branch active"}</span>
                  </button>

                  <button
                    class="type-card__expand"
                    type="button"
                    aria-expanded="false"
                    aria-label={`Expand ${type} asset filters`}
                    data-type-expand={type}
                  >
                    <span class="type-card__chevron" aria-hidden="true"></span>
                  </button>
                </div>

                <div class="type-card__assets" data-type-assets-panel={type} hidden>
                  <button
                    type="button"
                    class="type-asset-row type-asset-row--all"
                    data-asset-button={type}
                    data-asset-type={type}
                    data-asset-value=""
                  >
                    <span class="type-asset-row__label">ALL</span>
                    <span class="type-asset-row__count">
                      {formatCount(typeFilter?.totalCount ?? 0)}
                    </span>
                  </button>

                  {
                    typeFilter?.assets.map(({ asset, count }) => (
                      <button
                        type="button"
                        class="type-asset-row"
                        data-asset-button={type}
                        data-asset-type={type}
                        data-asset-value={asset}
                      >
                        <span class="type-asset-row__label">{asset}</span>
                        <span class="type-asset-row__count">{formatCount(count)}</span>
                      </button>
                    ))
                  }

                  {
                    type === "instant" && (
                      <div class="type-timeframe-filter" data-timeframe-panel={type}>
                        <span class="type-timeframe-filter__label">TIMEFRAME</span>
                        <div class="type-timeframe-filter__grid">
                          <button
                            type="button"
                            class="type-timeframe-chip type-timeframe-chip--all"
                            data-timeframe-button={type}
                            data-timeframe-type={type}
                            data-timeframe-value=""
                          >
                            <span>ALL</span>
                            <span
                              data-timeframe-count={type}
                              data-timeframe-count-value=""
                            >
                              {formatCount(typeFilter?.totalCount ?? 0)}
                            </span>
                          </button>

                          {
                            typeFilter?.timeframes.map(({ timeframe, count }) => (
                              <button
                                type="button"
                                class="type-timeframe-chip"
                                data-timeframe-button={type}
                                data-timeframe-type={type}
                                data-timeframe-value={timeframe}
                              >
                                <span>{timeframe}</span>
                                <span
                                  data-timeframe-count={type}
                                  data-timeframe-count-value={timeframe}
                                >
                                  {formatCount(count)}
                                </span>
                              </button>
                            ))
                          }
                        </div>
                      </div>
                    )
                  }
                </div>
              </article>
            );
          })
        }
      </div>
    </ConsolePanel>

    <ConsolePanel title="RECENT" className="archive-console__feed">
      <div class="feed-list">
        {
          archives.map(({ Content, ...archive }, order) => (
            <article
              class:list={[
                "archive-item",
                {
                  "is-hidden": archive.type !== initialType,
                  "is-older-batch":
                    latestBatchKeyByType.get(archive.type) !== null &&
                    archive.slotTimeUtc !== latestBatchKeyByType.get(archive.type)
                }
              ]}
              data-archive-item={archive.id}
              data-archive-type={archive.type}
              data-archive-asset={archive.asset}
              data-archive-timeframes={archive.tradingviewTimeframes.join("|")}
              data-archive-order={order}
              hidden={archive.type !== initialType}
            >
              <button
                type="button"
                class="archive-item__toggle"
                aria-expanded="false"
                data-archive-toggle={archive.id}
              >
                <span class="archive-item__topline">
                  <span class="archive-item__meta">
                    <span class="archive-item__timeframe">
                      {archive.timeframeLabel}
                    </span>
                    <span
                      class:list={[
                        "bias-tag",
                        `bias-tag--${archive.bias.toLowerCase()}`
                      ]}
                    >
                      {archive.bias}
                    </span>
                  </span>
                  <span class="archive-item__date">{archive.dateDisplay}</span>
                </span>
                <span class="archive-item__title">{archive.title}</span>
              </button>

              <div class="archive-item__body" data-archive-body={archive.id} hidden>
                <article class="archive-item__content prose prose--archive">
                  <Content />
                </article>
              </div>
            </article>
          ))
        }
      </div>
    </ConsolePanel>

    <ConsolePanel title="ASSET" className="archive-console__detail">
      <div class="detail-stack">
        {
          Array.from({ length: widgetCount }, (_, index) => (
            <div class="widget-shell widget-shell--archive" data-widget-shell={index}>
              <div class="widget-shell__header">
                <span data-detail-symbol={index}>--</span>
                <span data-detail-interval={index}>{initialIntervals[index] ?? "--"}</span>
              </div>
              <div class="tv-chart tv-chart--compact" data-detail-chart={index}>
                <div class="tv-chart__fallback">SELECT ARCHIVE</div>
              </div>
            </div>
          ))
        }

        <div class="detail-meta detail-meta--archive">
          <div class="detail-meta__row">
            <span>ASSET</span>
            <strong data-detail-asset>--</strong>
          </div>
          <div class="detail-meta__row">
            <span>TYPE</span>
            <strong data-detail-type>
              {typeDisplayLabels[initialType] ?? initialType.toUpperCase()}
            </strong>
          </div>
          <div class="detail-meta__row">
            <span>BIAS</span>
            <strong data-detail-bias>--</strong>
          </div>
          <div class="detail-meta__row">
            <span>UPDATED</span>
            <strong data-detail-date>--</strong>
          </div>
          <div class="detail-meta__row detail-meta__row--stack">
            <span>FILE ID</span>
            <strong data-detail-fileid>--</strong>
          </div>
        </div>

        <a
          class="action-link action-link--disabled"
          href="#"
          aria-disabled="true"
          data-detail-link
        >
          <span>OPEN FILE</span>
          <span class="action-link__chevron" aria-hidden="true"></span>
        </a>
      </div>
    </ConsolePanel>
  </div>
</section>

<script
  is:inline
  define:vars={{
    archiveIndex,
    initialType,
    types,
    timeframeDefaults,
    timeframeWidgetMap,
    typeFilterIndex,
    typeDisplayLabels
  }}
>
  //[Inicializa comportamento client-side uma unica vez, mesmo com transicoes Astro entre paginas.]
  const initArchiveConsole = () => {
    const root = document.querySelector("[data-archive-console]");
    const bindVersion = "parallax-relative-v1";
    if (!root || root.dataset.archiveBound === bindVersion) return;
    root.dataset.archiveBound = bindVersion;

    const typeCards = [...root.querySelectorAll("[data-type-card]")];
    const typeButtons = [...root.querySelectorAll("[data-type-button]")];
    const expandButtons = [...root.querySelectorAll("[data-type-expand]")];
    const assetFilterButtons = [...root.querySelectorAll("[data-asset-button]")];
    const timeframeFilterButtons = [...root.querySelectorAll("[data-timeframe-button]")];
    const timeframeCountNodes = [...root.querySelectorAll("[data-timeframe-count]")];
    const assetPanels = [...root.querySelectorAll("[data-type-assets-panel]")];
    const archiveItems = [...root.querySelectorAll("[data-archive-item]")];
    const toggleButtons = [...root.querySelectorAll("[data-archive-toggle]")];
    const bodyNodes = [...root.querySelectorAll("[data-archive-body]")];
    const widgetShells = [...root.querySelectorAll("[data-widget-shell]")];
    const chartNodes = [...root.querySelectorAll("[data-detail-chart]")];
    const symbolNodes = [...root.querySelectorAll("[data-detail-symbol]")];
    const intervalNodes = [...root.querySelectorAll("[data-detail-interval]")];
    const assetNode = root.querySelector("[data-detail-asset]");
    const typeNode = root.querySelector("[data-detail-type]");
    const biasNode = root.querySelector("[data-detail-bias]");
    const dateNode = root.querySelector("[data-detail-date]");
    const fileIdNode = root.querySelector("[data-detail-fileid]");
    const linkNode = root.querySelector("[data-detail-link]");

    //[Cria indices em memoria para lookup rapido de arquivos, tipos, elementos e bodies.]
    const archiveMap = new Map(archiveIndex.map((archive) => [archive.id, archive]));
    const typeFilterMap = new Map(
      typeFilterIndex.map((typeFilter) => [typeFilter.type, typeFilter])
    );
    const itemMap = new Map(
      archiveItems.map((item) => [item.dataset.archiveItem, item])
    );
    const bodyMap = new Map(
      bodyNodes.map((body) => [body.dataset.archiveBody, body])
    );
    const toggleMap = new Map(
      toggleButtons.map((button) => [button.dataset.archiveToggle, button])
    );

    const defaultIntervalsForType = (type) =>
      timeframeDefaults[type] ?? ["--"];

    const labelForType = (type) =>
      typeDisplayLabels[type] ?? String(type || "").toUpperCase();

    //[Converte timeframe exibido para intervalo esperado pela configuracao do widget TradingView.]
    const toWidgetInterval = (value) => timeframeWidgetMap[value] ?? value;

    const formatUiCount = (value) => String(value).padStart(2, "0");

    //[Confere se filtro de ativo existe no tipo atual antes de aceitar querystring.]
    const assetExistsInType = (type, asset) =>
      Boolean(
        asset &&
          typeFilterMap
            .get(type)
            ?.assets.some((typeFilter) => typeFilter.asset === asset)
      );

    const timeframeExistsInType = (type, timeframe) =>
      Boolean(
        type === "instant" &&
          timeframe &&
          archiveIndex.some(
            (archive) =>
              archive.type === type &&
              archive.tradingviewTimeframes.includes(timeframe)
          )
      );

    const archiveMatchesFilters = (
      archive,
      {
        type = activeType,
        asset = activeAsset,
        timeframe = activeTimeframe
      } = {}
    ) =>
      archive.type === type &&
      (!asset || archive.asset === asset) &&
      (!timeframe || archive.tradingviewTimeframes.includes(timeframe));

    const latestArchiveForFilters = () =>
      archiveIndex.find((archive) => archiveMatchesFilters(archive)) ?? null;

    const syncTimeframeCounts = () => {
      timeframeCountNodes.forEach((node) => {
        const type = node.dataset.timeframeCount;
        const timeframe = node.dataset.timeframeCountValue || null;
        const scopedAsset = type === activeType ? activeAsset : null;
        const count = archiveIndex.filter(
          (archive) =>
            archive.type === type &&
            (!scopedAsset || archive.asset === scopedAsset) &&
            (!timeframe || archive.tradingviewTimeframes.includes(timeframe))
        ).length;

        node.textContent = formatUiCount(count);
      });
    };

    //[Reduz feed em telas menores para manter console legivel e evitar scroll excessivo.]
    const getVisibleLimit = () =>
      window.matchMedia("(max-width: 840px)").matches ? 15 : 30;

    const renderWidgetFallback = (label) => {
      chartNodes.forEach((node) => {
        node.innerHTML = `<div class="tv-chart__fallback">${label}</div>`;
      });
    };

    const setDetailIntervals = (intervals) => {
      intervalNodes.forEach((node, index) => {
        node.textContent = intervals[index] ?? "--";
      });
    };

    const setDetailSymbol = (symbol) => {
      symbolNodes.forEach((node) => {
        node.textContent = symbol ?? "--";
      });
    };

    const syncWidgetVisibility = (intervals) => {
      widgetShells.forEach((shell, index) => {
        shell.hidden = index >= intervals.length;
      });
    };

    const syncTypeUi = () => {
      typeCards.forEach((card) => {
        const type = card.dataset.typeCard;
        const isActive = type === activeType;
        const isExpanded = expandedTypes.has(type);

        card.classList.toggle("is-active", isActive);
        card.classList.toggle("is-expanded", isExpanded);
      });

      typeButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.typeButton === activeType);
      });

      expandButtons.forEach((button) => {
        const type = button.dataset.typeExpand;
        const isActive = type === activeType;
        const isExpanded = expandedTypes.has(type);

        button.classList.toggle("is-active", isActive);
        button.classList.toggle("is-expanded", isExpanded);
        button.setAttribute("aria-expanded", String(isExpanded));
        button.setAttribute(
          "aria-label",
          `${isExpanded ? "Collapse" : "Expand"} ${type} asset filters`
        );
      });

      assetPanels.forEach((panel) => {
        const type = panel.dataset.typeAssetsPanel;
        panel.hidden = !expandedTypes.has(type);
      });

      assetFilterButtons.forEach((button) => {
        const type = button.dataset.assetType;
        const asset = button.dataset.assetValue || null;
        const isActiveButton =
          type === activeType &&
          ((asset === null && activeAsset === null) || asset === activeAsset);

        button.classList.toggle("is-active", isActiveButton);
      });

      timeframeFilterButtons.forEach((button) => {
        const type = button.dataset.timeframeType;
        const timeframe = button.dataset.timeframeValue || null;
        const isActiveButton =
          type === activeType &&
          ((timeframe === null && activeTimeframe === null) ||
            timeframe === activeTimeframe);

        button.classList.toggle("is-active", isActiveButton);
      });

      syncTimeframeCounts();
    };

    const collapseArchive = (archiveId) => {
      const item = itemMap.get(archiveId);
      const body = bodyMap.get(archiveId);
      const toggle = toggleMap.get(archiveId);

      if (item) item.classList.remove("is-active");
      if (body) body.hidden = true;
      if (toggle) toggle.setAttribute("aria-expanded", "false");
    };

    const collapseAll = () => {
      archiveIndex.forEach((archive) => collapseArchive(archive.id));
    };

    const syncArchiveLocation = () => {
      const params = new URLSearchParams();
      const activeArchive = activeArchiveId ? archiveMap.get(activeArchiveId) : null;
      const isDefaultState =
        activeType === initialType &&
        !activeAsset &&
        !activeTimeframe &&
        !activeArchive;
      let nextUrl = window.location.pathname;

      if (!isDefaultState) {
        params.set("type", activeType);

        if (activeAsset) {
          params.set("asset", activeAsset);
        }

        if (activeTimeframe) {
          params.set("timeframe", activeTimeframe);
        }

        if (activeArchive?.slug) {
          params.set("slug", activeArchive.slug);
        }

        const query = params.toString();
        nextUrl = query
          ? `${window.location.pathname}?${query}`
          : window.location.pathname;
      }

      window.history.replaceState(window.history.state, "", nextUrl);
    };

    const resolveInitialSelection = () => {
      const params = new URLSearchParams(window.location.search);
      const requestedType = params.get("type");
      const requestedAsset = params.get("asset");
      const requestedTimeframe = params.get("timeframe");
      const requestedSlug = params.get("slug");
      const archiveFromSlug = requestedSlug
        ? archiveIndex.find((archive) => archive.slug === requestedSlug)
        : null;
      const typeFromQuery = types.includes(requestedType ?? "") ? requestedType : null;
      const resolvedType = archiveFromSlug?.type ?? typeFromQuery ?? initialType;
      const archiveFromQuery =
        archiveFromSlug && archiveFromSlug.type === resolvedType
          ? archiveFromSlug
          : null;
      const resolvedAsset = requestedAsset
        ? archiveFromQuery?.asset ?? (
            assetExistsInType(resolvedType, requestedAsset) ? requestedAsset : null
          )
        : null;
      const resolvedTimeframe =
        resolvedType === "instant"
          ? archiveFromQuery?.tradingviewTimeframes[0] ?? (
              timeframeExistsInType(resolvedType, requestedTimeframe)
                ? requestedTimeframe
                : null
            )
          : null;

      return {
        type: resolvedType,
        asset: resolvedAsset,
        timeframe: resolvedTimeframe,
        archiveId: archiveFromQuery?.id ?? null,
        expandedTypes: resolvedAsset || resolvedTimeframe ? [resolvedType] : []
      };
    };

    let widgetRenderNonce = 0;
    let activeType = initialType;
    let activeAsset = null;
    let activeTimeframe = null;
    let activeArchiveId = null;
    let expandedTypes = new Set();

    //[Carrega script TradingView sob demanda e sinaliza falha sem travar console.]
    const ensureTradingView = async () => {
      if (window.TradingView?.widget) return true;

      let script = document.querySelector("script[data-tv-script]");
      if (!script) {
        script = document.createElement("script");
        script.src = "https://s3.tradingview.com/tv.js";
        script.async = true;
        script.dataset.tvScript = "true";
        document.head.appendChild(script);
      }

      await new Promise((resolve, reject) => {
        if (window.TradingView?.widget) {
          resolve(true);
          return;
        }

        script.addEventListener("load", () => resolve(true), { once: true });
        script.addEventListener("error", () => reject(new Error("tv-load")), {
          once: true
        });
      }).catch(() => false);

      return Boolean(window.TradingView?.widget);
    };

    //[Renderiza widgets do arquivo ativo, protegendo contra respostas antigas assincronas.]
    const renderWidgets = async (archive) => {
      const nonce = ++widgetRenderNonce;

      if (!archive) {
        const fallbackIntervals = defaultIntervalsForType(activeType);

        renderWidgetFallback("SELECT ARCHIVE");
        syncWidgetVisibility(fallbackIntervals);
        return;
      }

      chartNodes.forEach((node) => {
        node.innerHTML = "";
      });

      const tvReady = await ensureTradingView();
      if (!tvReady || nonce !== widgetRenderNonce) {
        renderWidgetFallback("TRADINGVIEW UNAVAILABLE");
        return;
      }

      const commonConfig = {
        symbol: archive.tradingviewSymbol,
        theme: "dark",
        style: "1",
        locale: "en",
        autosize: true,
        allow_symbol_change: false,
        hide_top_toolbar: true,
        hide_legend: true,
        save_image: false,
        backgroundColor: "#020603",
        gridColor: "rgba(157,255,191,0.08)"
      };

      chartNodes.forEach((node, index) => {
        if (index >= archive.tradingviewTimeframes.length) {
          node.innerHTML = "";
          return;
        }

        const frameId = `tv-archive-${index}`;
        node.innerHTML = `<div id="${frameId}"></div>`;

        new window.TradingView.widget({
          ...commonConfig,
          interval: toWidgetInterval(archive.tradingviewTimeframes[index]),
          container_id: frameId
        });
      });
    };

    //[Atualiza painel lateral com metadata, link e widgets do arquivo selecionado.]
    const showDetailForArchive = async (archive) => {
      if (!archive) {
        const fallbackIntervals = defaultIntervalsForType(activeType);
        if (assetNode) assetNode.textContent = "--";
        if (typeNode) typeNode.textContent = labelForType(activeType);
        if (biasNode) biasNode.textContent = "--";
        if (dateNode) dateNode.textContent = "--";
        if (fileIdNode) fileIdNode.textContent = "--";
        if (linkNode) {
          linkNode.href = "#";
          linkNode.setAttribute("aria-disabled", "true");
          linkNode.classList.add("action-link--disabled");
        }

        setDetailSymbol("--");
        syncWidgetVisibility(fallbackIntervals);
        setDetailIntervals(fallbackIntervals);
        syncArchiveLocation();
        await renderWidgets(null);
        return;
      }

      if (assetNode) assetNode.textContent = archive.asset;
      if (typeNode) typeNode.textContent = archive.typeLabel;
      if (biasNode) biasNode.textContent = archive.bias;
      if (dateNode) dateNode.textContent = archive.dateDisplay;
      if (fileIdNode) fileIdNode.textContent = archive.fileId;
      if (linkNode) {
        linkNode.href = archive.url;
        linkNode.removeAttribute("aria-disabled");
        linkNode.classList.remove("action-link--disabled");
      }

      setDetailSymbol(archive.tradingviewSymbol);
      syncWidgetVisibility(archive.tradingviewTimeframes);
      setDetailIntervals(archive.tradingviewTimeframes);
      syncArchiveLocation();
      await renderWidgets(archive);
    };

    //[Escolhe arquivo detalhado por selecao explicita, filtro ativo ou item mais recente.]
    const syncDetail = async () => {
      const activeArchive = activeArchiveId ? archiveMap.get(activeArchiveId) : null;
      const filteredArchive = !activeArchive ? latestArchiveForFilters() : null;

      await showDetailForArchive(activeArchive ?? filteredArchive);
    };

    //[Fecha arquivo aberto quando filtro ou limite de feed torna selecao invalida.]
    const resetOpenArchive = () => {
      if (activeArchiveId) {
        collapseArchive(activeArchiveId);
      }

      activeArchiveId = null;
    };

    //[Mostra somente itens compativeis com tipo, ativo e limite responsivo atual.]
    const updateFeedVisibility = () => {
      let shown = 0;
      const visibleLimit = getVisibleLimit();

      archiveItems.forEach((item) => {
        const matchesType = item.dataset.archiveType === activeType;
        const matchesAsset =
          !activeAsset || item.dataset.archiveAsset === activeAsset;
        const matchesTimeframe =
          !activeTimeframe ||
          (item.dataset.archiveTimeframes ?? "")
            .split("|")
            .includes(activeTimeframe);
        const isPinnedActive = item.dataset.archiveItem === activeArchiveId;
        const visible =
          matchesType &&
          matchesAsset &&
          matchesTimeframe &&
          (shown < visibleLimit || isPinnedActive);

        item.hidden = !visible;
        item.classList.toggle("is-hidden", !visible);

        if (matchesType && matchesAsset && matchesTimeframe && !isPinnedActive) {
          shown += 1;
        }
      });

      const activeItem = activeArchiveId ? itemMap.get(activeArchiveId) : null;
      if (activeArchiveId && (!activeItem || activeItem.hidden)) {
        resetOpenArchive();
      }
    };

    //[Abre arquivo no feed, sincronizando tipo, ativo, corpo expandido e painel asset.]
    const openArchive = async (archiveId) => {
      const archive = archiveMap.get(archiveId);
      const item = itemMap.get(archiveId);
      const body = bodyMap.get(archiveId);
      const toggle = toggleMap.get(archiveId);

      if (!archive || !item || !body || !toggle) return;

      activeType = archive.type;
      if (activeAsset && activeAsset !== archive.asset) {
        activeAsset = archive.asset;
      }
      if (
        activeTimeframe &&
        !archive.tradingviewTimeframes.includes(activeTimeframe)
      ) {
        activeTimeframe =
          archive.type === "instant" ? archive.tradingviewTimeframes[0] : null;
      }

      collapseAll();
      activeArchiveId = archive.id;
      syncTypeUi();
      updateFeedVisibility();
      item.classList.add("is-active");
      body.hidden = false;
      toggle.setAttribute("aria-expanded", "true");
      await syncDetail();
    };

    //[Troca tipo ativo, limpa selecoes dependentes e redesenha filtros, feed e detalhes.]
    const setActiveType = async (type, { expand = false } = {}) => {
      activeType = type;
      activeAsset = null;
      activeTimeframe = null;
      if (expand) expandedTypes.add(type);
      collapseAll();
      activeArchiveId = null;
      syncTypeUi();
      updateFeedVisibility();
      await syncDetail();
    };

    //[Aplica filtro de ativo dentro do tipo corrente e escolhe novo detalhe padrao.]
    const setActiveAsset = async (type, asset) => {
      const previousType = activeType;
      activeType = type;
      activeAsset = asset;
      if (type !== "instant" || previousType !== type) {
        activeTimeframe = null;
      }
      expandedTypes.add(type);
      collapseAll();
      activeArchiveId = null;
      syncTypeUi();
      updateFeedVisibility();
      await syncDetail();
    };

    const setActiveTimeframe = async (type, timeframe) => {
      const previousType = activeType;
      if (type !== "instant") return;
      activeType = type;
      if (previousType !== type) {
        activeAsset = null;
      }
      activeTimeframe = timeframe;
      expandedTypes.add(type);
      collapseAll();
      activeArchiveId = null;
      syncTypeUi();
      updateFeedVisibility();
      await syncDetail();
    };

    //[Abre ou fecha lista de ativos, alternando tipo quando usuario expande outro card.]
    const toggleExpandedType = async (type) => {
      if (expandedTypes.has(type)) {
        expandedTypes.delete(type);
        if (type === activeType) {
          activeAsset = null;
          activeTimeframe = null;
          collapseAll();
          activeArchiveId = null;
          syncTypeUi();
          updateFeedVisibility();
          await syncDetail();
          return;
        }

        syncTypeUi();
        return;
      }

      if (type !== activeType) {
        await setActiveType(type, { expand: true });
        return;
      }

      expandedTypes.add(type);
      syncTypeUi();
    };

    //[Registra handlers via delegacao para sobreviver a swaps de DOM em dev e transicoes.]
    root.addEventListener("click", async (event) => {
      if (!(event.target instanceof Element)) return;

      const typeButton = event.target.closest("[data-type-button]");
      if (typeButton && root.contains(typeButton)) {
        const nextType = typeButton.dataset.typeButton;
        if (!nextType || nextType === activeType) return;
        await setActiveType(nextType);
        return;
      }

      const expandButton = event.target.closest("[data-type-expand]");
      if (expandButton && root.contains(expandButton)) {
        const type = expandButton.dataset.typeExpand;
        if (!type) return;
        await toggleExpandedType(type);
        return;
      }

      const assetButton = event.target.closest("[data-asset-button]");
      if (assetButton && root.contains(assetButton)) {
        const type = assetButton.dataset.assetType;
        if (!type) return;
        const asset = assetButton.dataset.assetValue || null;
        const nextAsset =
          type === activeType && asset === activeAsset ? null : asset;
        await setActiveAsset(type, nextAsset);
        return;
      }

      const timeframeButton = event.target.closest("[data-timeframe-button]");
      if (timeframeButton && root.contains(timeframeButton)) {
        const type = timeframeButton.dataset.timeframeType;
        if (!type) return;
        const timeframe = timeframeButton.dataset.timeframeValue || null;
        const nextTimeframe =
          type === activeType && timeframe === activeTimeframe ? null : timeframe;
        await setActiveTimeframe(type, nextTimeframe);
        return;
      }

      const toggleButton = event.target.closest("[data-archive-toggle]");
      if (toggleButton && root.contains(toggleButton)) {
        const archiveId = toggleButton.dataset.archiveToggle;
        if (!archiveId) return;

        if (activeArchiveId === archiveId) {
          collapseArchive(archiveId);
          activeArchiveId = null;
          await syncDetail();
          return;
        }

        await openArchive(archiveId);
      }
    }, { capture: true });

    const initialSelection = resolveInitialSelection();
    activeType = initialSelection.type;
    activeAsset = initialSelection.asset;
    activeTimeframe = initialSelection.timeframe;
    activeArchiveId = initialSelection.archiveId;
    expandedTypes = new Set(initialSelection.expandedTypes);

    syncTypeUi();
    updateFeedVisibility();

    if (initialSelection.archiveId) {
      void openArchive(initialSelection.archiveId);
    } else {
      void syncDetail();
    }

    window.addEventListener("resize", () => {
      updateFeedVisibility();
      void syncDetail();
    });
  };

  //[Garante inicializacao depois de navegacao Astro e tambem na primeira carga direta.]
  if (!window.__matrixArchiveConsoleInit) {
    window.__matrixArchiveConsoleInit = true;
    document.addEventListener("astro:page-load", initArchiveConsole);
    initArchiveConsole();
  } else {
    initArchiveConsole();
  }
</script>
