---
//[Importa roteador de transicoes e CSS global aplicados a todas paginas Astro.]
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

//[Define props basicas para titulo, descricao e classe raiz de pagina.]
interface Props {
  title: string;
  description?: string;
  pageClass?: string;
}

const {
  title,
  description = "Matrix Archive of technical market analysis.",
  pageClass = ""
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Oxanium:wght@400;500;700&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body class={pageClass}>
    <slot />
  </body>
</html>
